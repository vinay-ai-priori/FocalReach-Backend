# --- Application ---
APP_NAME=FocalReach Outbound Engine
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Database (Neon Postgres) ---
# Example: postgresql+psycopg2://user:password@ep-xxx.us-east-2.aws.neon.tech/focalreach?sslmode=require
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/focalreach

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
AI_CACHE_TTL_SECONDS=604800

# --- Website Intelligence ---
WEBSITE_CACHE_TTL_SECONDS=604800
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_USER_AGENT=FocalReachBot/1.0 (+https://focalreach.ai)
CRAWLER_MAX_PAGES=5
MIN_CONTENT_LENGTH_FOR_PLAYWRIGHT_FALLBACK=400

# --- Cal.com OAuth ("Connect Calendar") ---
CALCOM_CLIENT_ID=
CALCOM_CLIENT_SECRET=
CALCOM_REDIRECT_URI=http://localhost:5173/connect-calendar
CALCOM_OAUTH_AUTHORIZE_URL=https://app.cal.com/auth/oauth2/authorize
CALCOM_OAUTH_TOKEN_URL=https://api.cal.com/v2/auth/oauth2/token
CALCOM_API_BASE_URL=https://api.cal.com/v2
CALCOM_OAUTH_SCOPES=EVENT_TYPE_READ EVENT_TYPE_WRITE BOOKING_READ BOOKING_WRITE SCHEDULE_READ SCHEDULE_WRITE PROFILE_READ PROFILE_WRITE
CALCOM_TOKEN_REFRESH_BUFFER_SECONDS=300

# --- Auth ---
JWT_SECRET=generate-a-long-random-string-here
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
# The app owner account, created once via: python -m app.cli seed-superadmin
SUPERADMIN_EMAIL=owner@focalreach.ai
SUPERADMIN_PASSWORD=ChangeMe123

# --- Mailbox connections ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAILBOX_CREDENTIALS_KEY=
